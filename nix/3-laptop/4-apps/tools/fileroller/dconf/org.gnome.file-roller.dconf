[dialogs/extract]
height=800
recreate-folders=true
skip-newer=false
width=1000

[dialogs/new]
default-extension='.tar.gz'
encrypt-header=false
expand-options=true
volume-size=0

[file-selector]
show-hidden=false
sidebar-size=300
sort-method='name'
sort-type='ascending'
window-size=(-1, -1)

[listing]
list-mode='as-folder'
name-column-width=464
show-path=false
sort-method='name'
sort-type='ascending'

[ui]
sidebar-width=200
view-sidebar=true
window-height=480
window-width=600
